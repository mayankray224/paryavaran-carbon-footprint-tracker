# Paryavaran Carbon Footprint Tracker - Environment Configuration
# Copy this file to .env and configure values

# Security Secret Key (Run: openssl rand -hex 32 to generate a secure key)
SECRET_KEY=supersecretkeyreplaceinproduction1234567890abcdef

# Token Expiration (in minutes) - 1440 minutes = 24 hours
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Connection URL (SQLite default for local development)
DATABASE_URL=sqlite:///./paryavaran.db

# App Environment (development/production/testing)
ENV=development
